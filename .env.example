# TimeSense — Environment Variables Template
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# ─────────────────────────────────────────────
# Jira
# ─────────────────────────────────────────────
JIRA_BASE_URL=https://yourteam.atlassian.net
JIRA_PROJECT_KEY=TIME
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your_jira_api_token_here

# ─────────────────────────────────────────────
# GitHub
# ─────────────────────────────────────────────
GITHUB_REPO=owner/TimeSense

# ─────────────────────────────────────────────
# Backend
# ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://timesense:timesense@localhost:5432/timesense
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change_me_to_a_long_random_string

# ─────────────────────────────────────────────
# Firebase Auth
# ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=

# ─────────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# Apple
# ─────────────────────────────────────────────
APPLE_BUNDLE_ID=
APPLE_TEAM_ID=
APPLE_APP_STORE_CONNECT_KEY_ID=
APPLE_APP_STORE_CONNECT_ISSUER_ID=
APPLE_APP_STORE_CONNECT_PRIVATE_KEY=

# ─────────────────────────────────────────────
# Google Play
# ─────────────────────────────────────────────
GOOGLE_PLAY_PACKAGE_NAME=
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# ─────────────────────────────────────────────
# LLM / OpenAI
# ─────────────────────────────────────────────
OPENAI_API_KEY=

# ─────────────────────────────────────────────
# Google OAuth (Calendar)
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────
# Microsoft OAuth (Outlook)
# ─────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ─────────────────────────────────────────────
# Slack
# ─────────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# ─────────────────────────────────────────────
# Todoist
# ─────────────────────────────────────────────
TODOIST_CLIENT_ID=
TODOIST_CLIENT_SECRET=

# ─────────────────────────────────────────────
# Notion
# ─────────────────────────────────────────────
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
