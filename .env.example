# TimeSense — Environment Variables Template
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# ─────────────────────────────────────────────
# Jira
# ─────────────────────────────────────────────
JIRA_BASE_URL=https://yourteam.atlassian.net
JIRA_PROJECT_KEY=TIME
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your_jira_api_token_here

# ─────────────────────────────────────────────
# GitHub
# ─────────────────────────────────────────────
GITHUB_REPO=owner/TimeSense

# ─────────────────────────────────────────────
# Backend
# ─────────────────────────────────────────────
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true
DATABASE_URL=postgresql+asyncpg://timesense:timesense@localhost:5432/timesense
DATABASE_URL_SYNC=postgresql://timesense:timesense@localhost:5432/timesense
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change_me_to_a_long_random_string
# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────────────────────
# Firebase Auth
# ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=

# ─────────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
STRIPE_PRICE_FOUNDER=

# ─────────────────────────────────────────────
# Apple
# ─────────────────────────────────────────────
APPLE_BUNDLE_ID=
APPLE_TEAM_ID=
APPLE_APP_STORE_CONNECT_KEY_ID=
APPLE_APP_STORE_CONNECT_ISSUER_ID=
APPLE_APP_STORE_CONNECT_PRIVATE_KEY=

# ─────────────────────────────────────────────
# Google Play
# ─────────────────────────────────────────────
GOOGLE_PLAY_PACKAGE_NAME=
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# ─────────────────────────────────────────────
# APNs (Apple push notifications)
# ─────────────────────────────────────────────
# Token-based (JWT) auth. Leave APNS_KEY_ID blank to disable proactive push (no-op sender).
# APNS_PRIVATE_KEY = the full contents of your AuthKey_XXXX.p8 (PEM). If putting it on one line,
# escape newlines as \n. Set APNS_USE_SANDBOX=false for production (App Store) builds.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY=
APNS_BUNDLE_ID=com.timesense.app
APNS_USE_SANDBOX=true

# ─────────────────────────────────────────────
# Maps (location-aware recommendations)
# ─────────────────────────────────────────────
# Server-side geocoding / nearby places / driving time. Enable Geocoding, Places, and
# Distance Matrix APIs on the key. Leave blank to disable location travel features (the engine
# safely falls back to low-confidence and never invents distances).
GOOGLE_MAPS_API_KEY=

# ─────────────────────────────────────────────
# LLM / OpenAI
# ─────────────────────────────────────────────
OPENAI_API_KEY=
LLM_DEFAULT_PROVIDER=openai
LLM_DEFAULT_MODEL=gpt-4o

# ─────────────────────────────────────────────
# Google OAuth — ONE app serves both Calendar and Gmail (read-only).
# Register BOTH redirect URIs on the same OAuth client; enable the Calendar API + Gmail API.
# See docs/integrations_setup.md.
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/integrations/google/callback
GMAIL_REDIRECT_URI=http://localhost:8000/api/v1/integrations/gmail/callback

# ─────────────────────────────────────────────
# Microsoft OAuth (Outlook)
# ─────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/integrations/microsoft/callback

# ─────────────────────────────────────────────
# Slack — requires an HTTPS redirect (use an ngrok/https URL for local dev; plain
# http://localhost is rejected by Slack).
# ─────────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_REDIRECT_URI=http://localhost:8000/api/v1/integrations/slack/callback

# ─────────────────────────────────────────────
# Dev / testing overrides
# ─────────────────────────────────────────────
# Comma-separated emails always treated as Premium (so premium features are testable past the
# 14-day intro trial). Leave empty in production.
PREMIUM_TEST_EMAILS=

# ─────────────────────────────────────────────
# Todoist
# ─────────────────────────────────────────────
TODOIST_CLIENT_ID=
TODOIST_CLIENT_SECRET=

# ─────────────────────────────────────────────
# Notion
# ─────────────────────────────────────────────
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
