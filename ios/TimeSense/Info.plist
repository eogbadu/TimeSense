<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Disable Firebase's UIApplicationDelegate method swizzling. FirebaseAuth otherwise intercepts
	     didRegisterForRemoteNotificationsWithDeviceToken and doesn't forward it to our
	     @UIApplicationDelegateAdaptor delegate, so our APNs token callback never fires. We don't use
	     FCM or phone-auth, so turning the proxy off is safe and lets our delegate receive the token. -->
	<key>FirebaseAppDelegateProxyEnabled</key>
	<false/>
	<!-- Allow plain-HTTP connections to the local network (e.g. the dev backend on the Mac reached
	     via its .local Bonjour name) while keeping App Transport Security on for everything else. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<!-- iOS 14+ requires a purpose string before the app makes local-network connections. -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>TimeSense connects to your development server on the local network.</string>
	<!-- Apple Health (read-only): sleep to estimate your energy, and steps/activity for your daily
	     summary. TimeSense never writes to Health. -->
	<key>NSHealthShareUsageDescription</key>
	<string>TimeSense reads your sleep and activity (steps, energy, exercise) to gauge your energy and show your daily summary. It never writes to Health.</string>
	<!-- Voice capture: transcribe speech on-device into a task. Raw audio is never stored. -->
	<key>NSMicrophoneUsageDescription</key>
	<string>TimeSense uses the microphone to turn what you say into a task. Your audio is never stored.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>TimeSense transcribes your speech (on-device where possible) so you can capture tasks by voice.</string>
	<!-- Calendar (EventKit): read event times/locations to find free blocks and time recommendations,
	     and (with your approval) add events. Covers any calendars added to iOS, including Google. -->
	<key>NSCalendarsFullAccessUsageDescription</key>
	<string>TimeSense reads your calendar to find free blocks and recommend the right task at the right time, and can add events you approve.</string>
	<key>NSCalendarsUsageDescription</key>
	<string>TimeSense reads your calendar to find free blocks and recommend the right task at the right time.</string>
	<!-- Location: used to recommend the right task at the right place and (with Always) notify you
	     when you arrive at or leave a saved place. Raw location points are never stored. -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>TimeSense uses your location to recommend the right task for where you are. Your location is never stored.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>With Always access, TimeSense can notify you about your best next task when you arrive at or leave a saved place (like Home or Work). Raw location is never stored.</string>
	<!-- Region monitoring wakes the app in the background on geofence events; remote-notification
	     lets APNs pushes wake the app. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>remote-notification</string>
	</array>
</dict>
</plist>
