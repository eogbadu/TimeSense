<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Allow plain-HTTP connections to the local network (e.g. the dev backend on the Mac reached
	     via its .local Bonjour name) while keeping App Transport Security on for everything else. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<!-- iOS 14+ requires a purpose string before the app makes local-network connections. -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>TimeSense connects to your development server on the local network.</string>
	<!-- Location: used to recommend the right task at the right place and (with Always) notify you
	     when you arrive at or leave a saved place. Raw location points are never stored. -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>TimeSense uses your location to recommend the right task for where you are. Your location is never stored.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>With Always access, TimeSense can notify you about your best next task when you arrive at or leave a saved place (like Home or Work). Raw location is never stored.</string>
	<!-- Region monitoring wakes the app in the background on geofence events; remote-notification
	     lets APNs pushes wake the app. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>remote-notification</string>
	</array>
</dict>
</plist>
